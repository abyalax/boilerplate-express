{
  "name": "express",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "biome lint --write",
    "start": "node build/server.cjs",
    "dev": "npx tsx watch src/index.ts",
    "compile": "npx tsc && npx tsc-alias && node extension.js",
    "build": "node esbuild.config.js",
    "db:seed": "env-cmd -f .env npx tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "path": "^0.12.7",
    "pg": "^8.16.3",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@jest/globals": "^30.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "env-cmd": "^11.0.0",
    "esbuild": "0.25.8",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.5",
    "nodemon": "^3.1.10",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
